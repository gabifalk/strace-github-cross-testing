CONFIG_DEBUG_INFO_NONE=y
CONFIG_NET_9P=y
CONFIG_NET_9P_VIRTIO=y
CONFIG_9P_FS=y
# virtio transports for the 9p shares: mmio for m68k "virt", ccw for s390x,
# pci for sparc64 "sun4u". Each is a no-op on arches that lack it.
CONFIG_VIRTIO=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_CCW=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_BLK=y
CONFIG_EXT4_FS=y
# CONFIG_SECURITY_LOCKDOWN_LSM is not set
# CONFIG_SECURITY_LOCKDOWN_LSM_EARLY is not set
# CONFIG_MODULE_SIG is not set
# CONFIG_IMA_APPRAISE_MODSIG is not set
