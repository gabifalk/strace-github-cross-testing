# CONFIG_VERSION: 12
BR2_m68k=y

BR2_GCC_VERSION_15_X=y
BR2_BINUTILS_VERSION_2_45_X=y

BR2_GLOBAL_PATCH_DIR="$(CI_TOP)/patches"

BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_USE_DEFCONFIG=y
BR2_LINUX_KERNEL_DEFCONFIG="virt"
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(CI_TOP)/linux-common-fragment"

# BR2_TARGET_ROOTFS_TAR is not set
BR2_TARGET_ROOTFS_CPIO=y
BR2_TARGET_ROOTFS_CPIO_FULL=y
BR2_ROOTFS_OVERLAY="$(CI_TOP)/rootfs-overlay"

BR2_PACKAGE_HOST_QEMU=y
BR2_PACKAGE_HOST_QEMU_SYSTEM_MODE=y
BR2_PACKAGE_HOST_QEMU_VIRTFS=y

BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y
BR2_PACKAGE_BUSYBOX_CONFIG_FRAGMENT_FILES="$(CI_TOP)/busybox-fragment"
BR2_PACKAGE_BASH=y
BR2_PACKAGE_MAKE=y
BR2_PACKAGE_SED=y
BR2_PACKAGE_GREP=y
BR2_PACKAGE_GAWK=y
BR2_PACKAGE_LIBSELINUX=y
BR2_PACKAGE_ELFUTILS=y
